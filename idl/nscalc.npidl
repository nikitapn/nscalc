module nscalc;

const GUEST_ID = 2;
const TARGET_ELEMENT_COUNT = 14;

enum ELEMENT { 
  N_NO3, N_NH4, P, K, Ca, Mg, S, Cl, Fe, Zn, B, Mn, Cu, Mo, 
  CO3, _P1, _P2, _P3, _P4, _P5, _P6, _P7, _P8, 
  H, O, C, NH4, NO3, SO4, H2PO4
};

message Solution {
  id: u32;
  userId: u32;
  userName: string;
  name: string;
  elements: f64[TARGET_ELEMENT_COUNT];
}

enum FertilizerBottle: u8 { A, B, C };

enum FertilizerType: u8 { Dry, Liquid, Solution };

message Fertilizer {
  id: u32;
  userId: u32;
  userName: string;
  name: string;
  formula: string;
  elements: f64[TARGET_ELEMENT_COUNT];
  bottle: FertilizerBottle;
  type: FertilizerType;
  density: f64;
  cost: f64;
}

message SolutionCursorPage {
  items: Solution[];
  next_cursor?: string;
}

message FertilizerCursorPage {
  items: Fertilizer[];
  next_cursor?: string;
}

message CalculatorBootstrap {
  solutions: Solution[];
  fertilizers: Fertilizer[];
}

message TargetElement  {
  value: f64;
  valueBase: f64;
  ratio: f64;
}

message Calculation {
  id: u32;
  name: string;
  elements: string; // TargetElement[TARGET_ELEMENT_COUNT]
  fertilizersIds: string; // vector<u32>;
  volume: f64;
  mode: boolean;
}

message Media {
  name: string;
  data: vector<u8>;
}

enum AuthorizationFailed_Reason: u8 {
  email_does_not_exist,
  incorrect_password,
  session_does_not_exist
}

exception AuthorizationFailed {
  reason: AuthorizationFailed_Reason;
}

enum RegistrationFailed_Reason: u8 {
  username_already_exist,
  email_already_registered,
  incorrect_code,
  invalid_username
}

exception RegistrationFailed {
  reason: RegistrationFailed_Reason;
}

exception PermissionViolation {
  msg: string;
}

exception InvalidArgument {
  msg: string;
}

message UserData {
  name: string;
  isAdmin: boolean;
  sessionId: string;
  db: object; // RegisteredUser
}

message SolutionElement {
  index: u32;
  value: f64;
}

enum AlarmType {
  Info,
  Warning,
  Critical
}

message Alarm {
  id: u32;
  type: AlarmType;
  msg: string;
}

enum ChatAttachmentType {
  Picture,
  File
}

message ChatAttachment {
  type: ChatAttachmentType;
  name: string;
  data: vector<u8>;
}

message ChatMessage {
  timestamp: u32;
  str: string;
  attachment?: ChatAttachment;
}

message Vector3 {
  x: f32;
  y: f32;
  z: f32;
}

message Vector2 {
  x: f32;
  y: f32;
}

message Footstep {
  color: Vector3;
  idx: u32;
  pos: Vector2;
  dir: Vector2;
}

message RealtimeClientEvent {
  footstep?: Footstep;
}

message RealtimeServerEvent {
  data_changed_idx?: u32;
  alarm?: Alarm;
  footstep?: Footstep;
}

interface Authorizator {
  UserData LogIn(login: in string, password: in string) raises(AuthorizationFailed);
  UserData LogInWithSessionId(session_id: in string) raises(AuthorizationFailed);
  boolean LogOut(session_id: in string);

  boolean CheckUsername(username: in string);
  boolean CheckEmail(email: in string);
  void RegisterStepOne(username: in string, email: in string, password: in string) raises(RegistrationFailed);
  void RegisterStepTwo(username: in string, code: in u32) raises(RegistrationFailed);
}

interface RegisteredUser {
  void GetMyCalculations(calculations: out direct vector<Calculation>);

  u32 AddSolution(name: in string, elements: in f64[TARGET_ELEMENT_COUNT]);
  void SetSolutionName(id: in u32, name: in string) raises(PermissionViolation);
  void SetSolutionElements(id: in u32, name: in vector<SolutionElement>) raises(PermissionViolation);
  void DeleteSolution(id: in u32) raises(PermissionViolation);

  u32 AddFertilizer(name: in string, formula: in string) raises(InvalidArgument);
  void SetFertilizerName(id: in u32, name: in string) raises(PermissionViolation);
  void SetFertilizerFormula(id: in u32, name: in string) raises(PermissionViolation, InvalidArgument);
  void DeleteFertilizer(id: in u32) raises(PermissionViolation);

  u32 UpdateCalculation(calculation: in Calculation);
  void DeleteCalculation(id: in u32);
}

// Stream-based replacement for Subscribe()/SendFootstep().
// Keep the legacy callback-object API during migration.
interface Realtime {
  bidi_stream<RealtimeClientEvent, RealtimeServerEvent> Connect(session_id: in string);
}

interface Chat {
  bidi_stream<ChatMessage, ChatMessage> Connect(session_id: in string);
}

interface Calculator {
  void GetData(solutions: out direct vector<Solution>, fertilizers: out direct vector<Fertilizer>);
  CalculatorBootstrap GetCalculatorBootstrap(solution_limit: in u32, fertilizer_limit: in u32);
  SolutionCursorPage ListSolutionsPage(query: in string, author: in string, cursor: in string, limit: in u32);
  FertilizerCursorPage ListFertilizersPage(query: in string, cursor: in string, limit: in u32);
  void Subscribe(obj: /*DataObserver*/ in object );
  void GetGuestCalculations(calculations: out direct vector<Calculation>);
  void SendFootstep(footstep: in Footstep);
}

interface SiteEventService {
  string GetSiteEventConfig();
  string SetSiteEventConfig(session_id: in string, config_json: in string) raises(AuthorizationFailed, PermissionViolation, InvalidArgument);
}

enum AssistantEventStatus {
  Thinking,
  ToolCall,
  Done,
  Error,
  Token
}

message AssistantImage {
  mime_type: string;
  data: vector<u8>;
}

// Prior turns the client resends so the model can continue a multi-turn
// conversation. The server is currently stateless across asks — the browser
// holds history (e.g. in IndexedDB) and includes it here. Images from earlier
// turns are intentionally omitted (text-only history).
enum AssistantMessageRole: u8 {
  User,
  Assistant
}

message AssistantHistoryTurn {
  role: AssistantMessageRole;
  content: string;
}

message AssistantAsk {
  request_id: string;
  prompt: string;
  image?: AssistantImage;
  history: AssistantHistoryTurn[];
}

message AssistantEvent {
  request_id: string;
  status: AssistantEventStatus;
  detail?: string;
  solution?: Solution;
  fertilizer?: Fertilizer;
}

interface AssistantService {
  bidi_stream<AssistantAsk, AssistantEvent> Connect(session_id: in string);
}

// Lets a compute worker (e.g. a laptop behind NAT, running Ollama + the RAG
// bridge) dial *out* to this server and receive relayed HTTP jobs over the
// resulting stream — the worker never needs to be reachable from the server,
// only vice versa. The worker is a dumb JSON-over-HTTP relay: it doesn't
// know Ollama's or the RAG bridge's schemas, it just POSTs request_body_json
// to the right local endpoint and streams back whatever comes down the wire.
enum ComputeJobKind {
  OllamaChatStream,
  RagSearch
}

enum ComputeJobResultStatus {
  Chunk,
  Done,
  Error
}

message ComputeJobRequest {
  job_id: string;
  kind: ComputeJobKind;
  request_body_json: string;
}

message ComputeJobResult {
  job_id: string;
  status: ComputeJobResultStatus;
  chunk_json?: string;
  error_message?: string;
}

interface ComputeChannel {
  bidi_stream<ComputeJobResult, ComputeJobRequest> Connect(worker_token: in string);
}
