{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "cppdbg",
      "request": "launch",
      "name": "Launch debug",
      "program": "${workspaceFolder}/.build_local/debug/${input:executableName}",
      "args": [
        "--hostname=archvm.lan",
        "--http-dir=./client/public",
        "--data-dir=./sample_data",
        "--use-ssl=1",
        "--public-key=certs/archvm.lan.crt",
        "--private-key=certs/archvm.lan.key",
        "--dh-params=certs/dhparam.pem"
      ],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "setupCommands": [
        {
          "description": "Enable Intel disassembly syntax",
          "text": "-gdb-set disassembly-flavor intel"
        }
      ]
    },
    {
      "type": "swift",
      "request": "launch",
      "args": [],
      "cwd": "${workspaceFolder:nscalc}/external/nprpc/nprpc_swift",
      "name": "Debug http3-server (external/nprpc/nprpc_swift)",
      "target": "http3-server",
      "configuration": "debug",
      "preLaunchTask": "swift: Build Debug http3-server (external/nprpc/nprpc_swift)"
    },
    {
      "type": "swift",
      "request": "launch",
      "args": [],
      "cwd": "${workspaceFolder:nscalc}/external/nprpc/nprpc_swift",
      "name": "Release http3-server (external/nprpc/nprpc_swift)",
      "target": "http3-server",
      "configuration": "release",
      "preLaunchTask": "swift: Build Release http3-server (external/nprpc/nprpc_swift)"
    },
    {
      "type": "swift",
      "request": "launch",
      "args": [],
      "cwd": "${workspaceFolder:nscalc}/server",
      "name": "Debug NScalcServer (server)",
      "target": "NScalcServer",
      "configuration": "debug",
      "preLaunchTask": "swift: Build Debug NScalcServer (server)"
    },
    {
      "type": "swift",
      "request": "launch",
      "args": [],
      "cwd": "${workspaceFolder:nscalc}/server",
      "name": "Release NScalcServer (server)",
      "target": "NScalcServer",
      "configuration": "release",
      "preLaunchTask": "swift: Build Release NScalcServer (server)"
    }
  ],
  "inputs": [
    {
      "type": "promptString",
      "id": "executableName",
      "description": "Enter the name of the executable to debug (e.g., nscalc, proxy_client)"
    }
  ]
}